{
  "presets": ["next/babel"],
  "plugins": [
    [
      "module-resolver",
      {
        "extensions": [".js", ".jsx", ".ts", ".tsx"],
        "alias": {
          "util": "./util",
          "utils": "./utils",
          "context": "./context",
          "components": "./components",
          "constants": "./constants",
          "hooks": "./hooks",
          "types": "./types",
          "pages": "./pages"
        }
      }
    ]
  ]
}
