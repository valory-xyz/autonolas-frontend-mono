{
  "presets": ["next/babel"],
  "plugins": [
    [
      "module-resolver",
      {
        "extensions": [".js", ".jsx", ".ts", ".tsx"],
        "alias": {
          "util": "./util",
          "common-util": "./common-util",
          "components": "./components",
          "context": "./context",
          "images": "./public/images",
          "store": "./store",
          "types": "./types"
        }
      }
    ],
    ["inline-react-svg"]
  ]
} 