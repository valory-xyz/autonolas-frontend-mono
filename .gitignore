# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
dist
tmp
/out-tsc

# dependencies
node_modules

# Only yarn.lock is authoritative — block stray npm / pnpm lockfiles
package-lock.json
pnpm-lock.yaml

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache

# Next.js
.next

# env
.env
.env.local

# others
ganache_data
.unlighthouse
.swc
*.tsbuildinfo
/.plans

# One-off supply-chain audit artifacts (yarn audit / outdated / SBOM
# snapshots). The living doc is SUPPLY-CHAIN-SECURITY.md and the
# allowlists in .supply-chain/. Anything left in /audit/ is a snapshot
# of a moment in time and goes stale quickly.
/audit/
